# Required -- real LLM narration will not work without this.
ANTHROPIC_API_KEY=sk-ant-...

# Optional secondary/fallback provider. If unset, Gemini fallback entries
# in sampark/config/models.yaml are skipped automatically -- no hard
# dependency, no error.
GEMINI_API_KEY=

# Optional overrides
SAMPARK_MODELS_CONFIG=sampark/config/models.yaml
SAMPARK_LEARNING_DB_PATH=sampark_learning.sqlite3
